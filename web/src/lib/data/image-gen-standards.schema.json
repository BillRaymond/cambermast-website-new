{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cambermast.com/schemas/image-gen-standards.schema.json",
  "title": "Cambermast Image Generation Prompt Standards Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updatedAt", "standards"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "standards": {
      "type": "array",
      "items": { "$ref": "#/$defs/standard" }
    }
  },
  "$defs": {
    "promptSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["square", "landscape", "portrait"],
      "properties": {
        "square": { "type": "string", "minLength": 1 },
        "landscape": { "type": "string", "minLength": 1 },
        "portrait": { "type": "string", "minLength": 1 }
      }
    },
    "assetKeySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["square", "landscape", "portrait"],
      "properties": {
        "square": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*/[^/]+$"
        },
        "landscape": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*/[^/]+$"
        },
        "portrait": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*/[^/]+$"
        }
      }
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "createdAt", "destinationType", "slug", "assetKeys", "prompts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]{8,64}$"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "destinationType": {
          "type": "string",
          "enum": ["events", "training", "resources", "featured-images", "custom"]
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*$"
        },
        "assetKeys": { "$ref": "#/$defs/assetKeySet" },
        "prompts": { "$ref": "#/$defs/promptSet" }
      }
    }
  }
}
