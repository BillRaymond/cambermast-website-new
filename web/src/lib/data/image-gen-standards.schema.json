{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cambermast.com/schemas/image-gen-standards.schema.json",
  "title": "Cambermast Image Generation Prompt Standards Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updatedAt", "formats", "standards"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "updatedAt": { "type": "string", "format": "date-time" },
    "formats": {
      "type": "object",
      "additionalProperties": false,
      "required": ["square", "landscape", "portrait"],
      "properties": {
        "square": { "$ref": "#/$defs/format" },
        "landscape": { "$ref": "#/$defs/format" },
        "portrait": { "$ref": "#/$defs/format" }
      }
    },
    "standards": {
      "type": "array",
      "items": { "$ref": "#/$defs/standard" }
    }
  },
  "$defs": {
    "format": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "aspectRatio", "label", "use"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "aspectRatio": { "type": "string", "pattern": "^[0-9]+:[0-9]+$" },
        "label": { "type": "string", "minLength": 1 },
        "use": { "type": "string", "minLength": 1 }
      }
    },
    "promptSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["square", "landscape", "portrait"],
      "properties": {
        "square": { "type": "string", "minLength": 1 },
        "landscape": { "type": "string", "minLength": 1 },
        "portrait": { "type": "string", "minLength": 1 }
      }
    },
    "assetKeySet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["square", "landscape", "portrait"],
      "properties": {
        "square": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*(?:\\.[^/]+|/[^/]+)$"
        },
        "landscape": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*(?:\\.[^/]+|/[^/]+)$"
        },
        "portrait": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*(?:\\.[^/]+|/[^/]+)$"
        }
      }
    },
    "standard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "createdAt", "entityType", "entitySlug", "assetKeys", "prompts", "reference"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]{8,64}$"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "entityType": {
          "type": "string",
          "enum": ["events", "training", "resources", "featured-images", "custom"]
        },
        "entitySlug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*(?:/[a-z0-9][a-z0-9-]*)*$"
        },
        "assetKeys": { "$ref": "#/$defs/assetKeySet" },
        "prompts": { "$ref": "#/$defs/promptSet" },
        "reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sourceType", "label"],
          "properties": {
            "url": {
              "type": ["string", "null"],
              "pattern": "^(\\/|https?:\\/\\/).+"
            },
            "sourceType": {
              "type": "string",
              "enum": [
                "none",
                "default_image",
                "training_reference",
                "local_template",
                "upload",
                "generated_asset",
                "manual",
                "legacy_migration"
              ]
            },
            "label": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
