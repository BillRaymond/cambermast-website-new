{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://cambermast.com/schemas/resources-api.schema.json",
	"title": "Resources API Response",
	"type": "object",
	"additionalProperties": false,
	"required": ["generatedAt", "resources"],
	"properties": {
		"generatedAt": { "type": "string", "format": "date-time" },
		"resources": {
			"type": "array",
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": [
					"id",
					"slug",
					"route",
					"url",
					"title",
					"summary",
					"category",
					"publishedAt",
					"images"
				],
				"properties": {
					"id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
					"slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
					"route": { "type": "string", "pattern": "^/resources/[a-z0-9]+(?:-[a-z0-9]+)*$" },
					"url": { "type": "string", "pattern": "^https?://" },
					"title": { "type": "string", "minLength": 1 },
					"summary": { "type": "string", "minLength": 1 },
					"category": { "type": "string", "minLength": 1 },
					"publishedAt": { "type": "string", "format": "date" },
					"author": { "type": "string", "minLength": 1 },
					"images": { "$ref": "#/$defs/entityImages" },
					"pdf": { "$ref": "#/$defs/resourcePdf" },
					"label": { "type": "string", "minLength": 1 }
				}
			}
		}
	},
	"$defs": {
		"resourcePdf": {
			"type": "object",
			"additionalProperties": false,
			"required": ["enabled", "printRoute", "url"],
			"properties": {
				"enabled": { "type": "boolean" },
				"printRoute": {
					"type": "string",
					"pattern": "^/resources/[a-z0-9]+(?:-[a-z0-9]+)*/print$"
				},
				"url": { "type": "string", "pattern": "^https?://" }
			}
		},
		"imageVariant": {
			"type": "object",
			"additionalProperties": false,
			"required": ["url"],
			"properties": {
				"url": { "type": "string", "pattern": "^https?://" }
			}
		},
		"imagePrompts": {
			"type": "object",
			"additionalProperties": false,
			"required": ["square", "landscape", "portrait"],
			"properties": {
				"square": { "type": "string" },
				"landscape": { "type": "string" },
				"portrait": { "type": "string" }
			}
		},
		"imageReference": {
			"type": "object",
			"additionalProperties": false,
			"required": ["sourceType", "label"],
			"properties": {
				"url": { "type": ["string", "null"], "pattern": "^https?://" },
				"sourceType": {
					"type": "string",
					"enum": [
						"none",
						"default_image",
						"training_reference",
						"local_template",
						"upload",
						"generated_asset",
						"manual",
						"legacy_migration"
					]
				},
				"label": { "type": "string", "minLength": 1 }
			}
		},
		"entityImages": {
			"type": "object",
			"additionalProperties": false,
			"required": ["current"],
			"properties": {
				"current": {
					"type": "object",
					"additionalProperties": false,
					"required": [
						"square",
						"landscape",
						"portrait",
						"alt",
						"kind",
						"prompts",
						"reference",
						"historyId"
					],
					"properties": {
						"square": { "$ref": "#/$defs/imageVariant" },
						"landscape": { "$ref": "#/$defs/imageVariant" },
						"portrait": { "$ref": "#/$defs/imageVariant" },
						"alt": { "type": "string", "minLength": 1 },
						"kind": { "type": "string", "enum": ["default", "generated", "manual"] },
						"prompts": { "$ref": "#/$defs/imagePrompts" },
						"reference": { "$ref": "#/$defs/imageReference" },
						"historyId": { "type": "string", "pattern": "^[a-z0-9]{8,64}$" }
					}
				}
			}
		}
	}
}
