{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://cambermast.com/schemas/resources.schema.json",
	"title": "Cambermast Resources Registry",
	"type": "object",
	"additionalProperties": false,
	"required": ["resources"],
	"properties": {
		"resources": {
			"type": "array",
			"items": { "$ref": "#/$defs/resourceEntry" }
		}
	},
	"$defs": {
		"resourceEntry": {
			"type": "object",
			"additionalProperties": false,
			"required": [
				"id",
				"slug",
				"route",
				"title",
				"summary",
				"category",
				"publishedAt"
			],
			"properties": {
				"id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
				"slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
				"route": { "type": "string", "pattern": "^/resources/[a-z0-9]+(?:-[a-z0-9]+)*$" },
				"title": { "type": "string", "minLength": 1 },
				"summary": { "type": "string", "minLength": 1 },
				"category": { "type": "string", "minLength": 1 },
				"publishedAt": { "type": "string", "format": "date" },
				"author": { "type": "string", "minLength": 1 },
				"imageSrc": { "type": "string", "pattern": "^(\\/|https?:\\/\\/).+" },
				"imageAlt": { "type": "string", "minLength": 1 },
				"label": { "type": "string", "minLength": 1 },
				"draft": { "type": "boolean" }
			}
		}
	}
}
