{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://cambermast.com/schemas/default-images.schema.json",
	"title": "Cambermast Default Image Sets Registry",
	"type": "object",
	"additionalProperties": false,
	"required": ["version", "updatedAt", "defaults"],
	"properties": {
		"version": { "type": "integer", "const": 1 },
		"updatedAt": { "type": "string", "format": "date-time" },
		"defaults": {
			"type": "object",
			"additionalProperties": false,
			"required": ["events", "training", "resources"],
			"properties": {
				"events": { "$ref": "#/$defs/defaultImageSet" },
				"training": { "$ref": "#/$defs/defaultImageSet" },
				"resources": { "$ref": "#/$defs/defaultImageSet" }
			}
		}
	},
	"$defs": {
		"defaultImageSet": {
			"type": "object",
			"additionalProperties": false,
			"required": ["square", "landscape", "portrait", "alt"],
			"properties": {
				"square": {
					"type": "string",
					"pattern": "^(\\/|https?:\\/\\/).+"
				},
				"landscape": {
					"type": "string",
					"pattern": "^(\\/|https?:\\/\\/).+"
				},
				"portrait": {
					"type": "string",
					"pattern": "^(\\/|https?:\\/\\/).+"
				},
				"alt": { "type": "string", "minLength": 1 }
			}
		}
	}
}
