{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"prebuild": "node ./scripts/sync-site-metadata.mjs && npm run validate:events && npm run validate:campaigns && npm run validate:registries && npm run validate:api && npm run validate:public-endpoints && npm run validate:schema-governance && npm run validate:ui-adapters && npm run validate:no-duplicate-files",
		"dev": "bash ./scripts/run-dev-with-training-pdf-watch.sh",
		"dev:vite": "vite dev",
		"predev": "node ./scripts/sync-site-metadata.mjs && npm run validate:events && npm run validate:campaigns && npm run validate:registries && npm run validate:api && npm run validate:public-endpoints && npm run validate:schema-governance && npm run validate:ui-adapters && npm run validate:no-duplicate-files",
		"dev:host": "vite dev --host 0.0.0.0 --port 5173",
		"build": "tsx ./scripts/reset-generated-output.ts && tsx ./scripts/generate-training-pdfs.ts --mode=dev --origin=https://www.cambermast.com && vite build && node ./scripts/write-static-admin-campaign-redirect.mjs",
		"preview": "vite preview",
		"prepreview": "node ./scripts/sync-site-metadata.mjs && npm run validate:events && npm run validate:campaigns && npm run validate:registries && npm run validate:api && npm run validate:public-endpoints && npm run validate:schema-governance && npm run validate:ui-adapters && npm run validate:no-duplicate-files",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"events:draft": "tsx ./scripts/generate-training-event-draft.ts",
		"campaigns:backfill-events": "tsx ./scripts/backfill-event-campaigns.ts --write",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"validate:campaigns": "tsx ./scripts/validate-campaigns.ts",
		"validate:events": "tsx ./scripts/validate-events.ts",
		"validate:catalog": "node ./scripts/validate-catalog.mjs",
		"validate:training": "node ./scripts/validate-training.mjs",
		"validate:faq-presets": "node ./scripts/validate-faq-presets.mjs",
		"validate:resources": "node ./scripts/validate-resources.mjs",
		"validate:default-images": "node ./scripts/validate-default-images.mjs",
		"validate:redirects": "tsx ./scripts/validate-redirects.ts",
		"validate:image-gen-standards": "node ./scripts/validate-image-gen-standards.mjs",
		"validate:tools": "node ./scripts/validate-tools.mjs",
		"validate:testimonials": "node ./scripts/validate-testimonials.mjs",
		"validate:registries": "npm run validate:catalog && npm run validate:training && npm run validate:faq-presets && npm run validate:resources && npm run validate:default-images && npm run validate:redirects && npm run validate:image-gen-standards && npm run validate:tools && npm run validate:testimonials",
		"validate:api": "tsx ./scripts/validate-api-responses.ts",
		"validate:public-endpoints": "tsx ./scripts/validate-public-endpoints.ts",
		"validate:no-duplicate-files": "node ./scripts/validate-no-duplicate-suffix-files.mjs",
		"validate:schema-governance": "node ./scripts/validate-schema-governance.mjs",
		"validate:ui-adapters": "tsx ./scripts/validate-ui-adapters.ts",
		"featured:compose-default": "node ./scripts/compose-featured-images.mjs",
		"generate:training-pdfs": "tsx ./scripts/generate-training-pdfs.ts",
		"watch:training-pdfs": "tsx ./scripts/watch-training-pdfs.ts",
		"generate:training-pdfs:dev": "tsx ./scripts/generate-training-pdfs.ts --mode=dev"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/postcss": "^4.2.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/qrcode": "^1.5.6",
		"@types/sanitize-html": "^2.16.1",
		"ajv": "^8.18.0",
		"ajv-formats": "^3.0.1",
		"autoprefixer": "^10.4.27",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^16.5.0",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"marked": "^17.0.5",
		"qrcode": "^1.5.4",
		"sanitize-html": "^2.17.2",
		"sharp": "^0.34.5"
	}
}
